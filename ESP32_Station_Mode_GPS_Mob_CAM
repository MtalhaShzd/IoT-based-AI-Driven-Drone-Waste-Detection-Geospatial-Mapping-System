// ============================================
// GPS Pins — Confirmed Working
// ============================================
#define GPS_RX_PIN       14
#define GPS_TX_PIN       47
#define GPS_BAUD         9600
#define LED_GPIO_NUM     21
#define GPS_FIX_TIMEOUT  30000

// ============================================
// GPS State
// ============================================
TinyGPSPlus       gps;
HardwareSerial    GPSSerial(1);
SemaphoreHandle_t gpsMutex         = NULL;

double        currentLat           = 0.0;
double        currentLng           = 0.0;
int           currentSats          = 0;
bool          gpsFix               = false;
unsigned long gpsCharsReceived     = 0;
unsigned long lastValidFix         = 0;
unsigned long lastStatusPrint      = 0;

// ============================================
// HTTP Server
// ============================================
httpd_handle_t gps_httpd = NULL;

// ============================================
// LED Task — Core 0
// ============================================
void ledTask(void* parameter) {
    pinMode(LED_GPIO_NUM, OUTPUT);
    digitalWrite(LED_GPIO_NUM, LOW);
    while (true) {
        if (gpsFix) {
            digitalWrite(LED_GPIO_NUM, HIGH);
            vTaskDelay(pdMS_TO_TICKS(200));
            digitalWrite(LED_GPIO_NUM, LOW);
            vTaskDelay(pdMS_TO_TICKS(200));
        } else {
            digitalWrite(LED_GPIO_NUM, HIGH);
            vTaskDelay(pdMS_TO_TICKS(1000));
            digitalWrite(LED_GPIO_NUM, LOW);
            vTaskDelay(pdMS_TO_TICKS(1000));
        }
    }
}

// ============================================
// GPS Functions
// ============================================
void readGPSUART() {
    while (GPSSerial.available()) {
        char c = GPSSerial.read();
        gps.encode(c);
        gpsCharsReceived++;
    }
}

void updateGPSState() {
    if (gpsMutex == NULL) return;
    if (xSemaphoreTake(gpsMutex,
            pdMS_TO_TICKS(50)) != pdTRUE) return;

    if (gps.location.isValid()
        && gps.location.isUpdated()
        && gps.satellites.isValid()
        && gps.satellites.value() > 0)
    {
        currentLat   = gps.location.lat();
        currentLng   = gps.location.lng();
        currentSats  = (int)gps.satellites.value();
        gpsFix       = true;
        lastValidFix = millis();
    }

    if (gpsFix
        && (millis() - lastValidFix > GPS_FIX_TIMEOUT))
    {
        gpsFix      = false;
        currentSats = 0;
        Serial.println("[GPS] ⚠ Fix lost");
    }

    xSemaphoreGive(gpsMutex);
}

void readGPS() {
    readGPSUART();
    updateGPSState();
}

// ============================================
// GPS JSON Endpoint — /gps
// ============================================
static esp_err_t gps_handler(httpd_req_t *req) {
    readGPSUART();

    unsigned long age = gps.location.isValid()
                        ? gps.location.age() : 99999;
    char json[300];
    snprintf(json, sizeof(json),
        "{"
          "\"lat\":%.6f,"
          "\"lng\":%.6f,"
          "\"satellites\":%d,"
          "\"fix\":%s,"
          "\"age_ms\":%lu,"
          "\"chars_received\":%lu"
        "}",
        currentLat, currentLng, currentSats,
        gpsFix ? "true" : "false",
        age, gpsCharsReceived
    );

    httpd_resp_set_type(req, "application/json");
    httpd_resp_set_hdr(req,
        "Access-Control-Allow-Origin", "*");
    httpd_resp_set_hdr(req, "Cache-Control", "no-cache");
    httpd_resp_sendstr(req, json);

    Serial.printf(
        "[GPS-API] lat:%.6f lng:%.6f sats:%d\n",
        currentLat, currentLng, currentSats);

    return ESP_OK;
}

