// ============================================
// Start Server
// ============================================
void startServer() {
    httpd_config_t cfg   = HTTPD_DEFAULT_CONFIG();
    cfg.max_uri_handlers = 4;
    cfg.stack_size       = 8192;

    if (httpd_start(&gps_httpd, &cfg) != ESP_OK) {
        Serial.println("[SERVER] Failed!");
        return;
    }

    static const httpd_uri_t u1 = {
        "/",   HTTP_GET, index_handler, NULL};
    static const httpd_uri_t u2 = {
        "/gps", HTTP_GET, gps_handler,  NULL};

    httpd_register_uri_handler(gps_httpd, &u1);
    httpd_register_uri_handler(gps_httpd, &u2);

    Serial.println("[SERVER] / and /gps ready");
}

// ============================================
// Connect WiFi with retry
// ============================================
void connectWiFi() {
    Serial.printf("[WIFI] Connecting to: %s\n", ssid);
    WiFi.mode(WIFI_STA);
    WiFi.begin(ssid, password);

    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
        attempts++;

        // Retry every 20 attempts
        if (attempts % 20 == 0) {
            Serial.println();
            Serial.printf("[WIFI] Still trying... (%d)\n",
                          attempts);
            WiFi.reconnect();
        }

        // Reboot after 60 attempts (30 seconds)
        if (attempts > 60) {
            Serial.println();
            Serial.println("[WIFI] Failed! Rebooting...");
            delay(3000);
            ESP.restart();
        }
    }

    Serial.println();
    Serial.println("[WIFI] Connected! ✓");
    Serial.printf("[WIFI] IP Address : %s\n",
                  WiFi.localIP().toString().c_str());
    Serial.printf("[WIFI] Signal     : %d dBm\n",
                  WiFi.RSSI());
    Serial.printf("[WIFI] Gateway    : %s\n",
                  WiFi.gatewayIP().toString().c_str());
}

// ============================================
// WiFi Reconnect Task — background
// Reconnects if WiFi drops during use
// ============================================
void wifiWatchdog(void* parameter) {
    while (true) {
        if (WiFi.status() != WL_CONNECTED) {
            Serial.println("[WIFI] Lost! Reconnecting...");
            WiFi.reconnect();
            int wait = 0;
            while (WiFi.status() != WL_CONNECTED
                   && wait < 20) {
                delay(1000);
                Serial.print(".");
                wait++;
            }
            if (WiFi.status() == WL_CONNECTED) {
                Serial.println();
                Serial.printf("[WIFI] Reconnected! IP: %s\n",
                    WiFi.localIP().toString().c_str());
            }
        }
        vTaskDelay(pdMS_TO_TICKS(5000)); // check every 5s
    }
}

// ============================================
// Wait For GPS Fix
// ============================================
void waitForGPSFix() {
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    Serial.println("[GPS] Waiting for fix...");
    Serial.printf("[GPS] RX=GPIO%d TX=GPIO%d\n",
                  GPS_RX_PIN, GPS_TX_PIN);
    Serial.println("[GPS] Antenna facing open sky!");
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

    unsigned long lastPrint = 0;
    unsigned long startMs   = millis();

    while (true) {
        readGPSUART();

        if (gps.location.isValid()
            && gps.satellites.isValid()
            && gps.satellites.value() > 0)
        {
            if (xSemaphoreTake(gpsMutex,
                    pdMS_TO_TICKS(100)) == pdTRUE) {
                currentLat   = gps.location.lat();
                currentLng   = gps.location.lng();
                currentSats  = (int)gps.satellites.value();
                gpsFix       = true;
                lastValidFix = millis();
                xSemaphoreGive(gpsMutex);
            }
        }

        unsigned long now = millis();
        if (now - lastPrint >= 2000) {
            lastPrint = now;
            int sats = gps.satellites.isValid()
                       ? (int)gps.satellites.value() : 0;

            Serial.printf(
                "[GPS] %lus | Chars:%lu | Sats:%d\n",
                (now - startMs) / 1000,
                gpsCharsReceived, sats);

            if (gpsCharsReceived == 0
                && (now - startMs) > 8000)
                Serial.println("[GPS] ✗ No data!");
            if (gpsCharsReceived > 100 && sats == 0)
                Serial.println("[GPS] ℹ Awaiting fix...");

            if (gpsFix) {
                Serial.println();
                Serial.println("╔═══════════════════════════════╗");
                Serial.println("║      GPS FIX ACQUIRED ✓       ║");
                Serial.printf("║  LAT: %11.6f°          ║\n",
                              currentLat);
                Serial.printf("║  LNG: %11.6f°          ║\n",
                              currentLng);
                Serial.printf("║  SAT: %-2d                      ║\n",
                              currentSats);
                Serial.println("╚═══════════════════════════════╝");
                return;
            }
        }
        delay(20);
    }
}

// ============================================
// SETUP
// ============================================
void setup() {
    Serial.begin(115200);
    delay(2000);

    Serial.println();
    Serial.println("╔═══════════════════════════════╗");
    Serial.println("║  ESP32-S3 GPS — Station Mode  ║");
    Serial.println("╚═══════════════════════════════╝");
    Serial.println();

    // Mutex
    gpsMutex = xSemaphoreCreateMutex();
    if (gpsMutex == NULL) {
        Serial.println("[ERROR] Mutex failed!");
        ESP.restart();
    }

    // LED Task — Core 0
    xTaskCreatePinnedToCore(
        ledTask, "LED", 1024, NULL, 1, NULL, 0);

    // GPS UART
    Serial.printf("[1/3] GPS RX=GPIO%d TX=GPIO%d\n",
                  GPS_RX_PIN, GPS_TX_PIN);
    GPSSerial.begin(GPS_BAUD, SERIAL_8N1,
                    GPS_RX_PIN, GPS_TX_PIN);
    delay(500);

    // GPS Fix first
    Serial.println("[2/3] Acquiring GPS fix...");
    waitForGPSFix();

    // WiFi Station
    Serial.println("[3/3] Connecting WiFi...");
    connectWiFi();

    // WiFi Watchdog — auto reconnect
    xTaskCreatePinnedToCore(
        wifiWatchdog, "WiFiWatch",
        4096, NULL, 1, NULL, 1);

    // HTTP Server
    startServer();

    Serial.println();
    Serial.println("╔═══════════════════════════════╗");
    Serial.println("║      SYSTEM READY ✓           ║");
    Serial.println("╠═══════════════════════════════╣");
    Serial.printf( "║  Network : %-19s║\n", ssid);
    Serial.printf( "║  ESP32 IP: %-19s║\n",
                   WiFi.localIP().toString().c_str());
    Serial.println("╠═══════════════════════════════╣");
    Serial.println("║  GPS Dashboard:               ║");
    Serial.printf( "║  http://%-22s║\n",
        (WiFi.localIP().toString() + "/").c_str());
    Serial.println("║  GPS JSON:                    ║");
    Serial.printf( "║  http://%-22s║\n",
        (WiFi.localIP().toString() + "/gps").c_str());
    Serial.println("╠═══════════════════════════════╣");
    Serial.println("║  LED: Fast=Fix Slow=Search    ║");
    Serial.println("╚═══════════════════════════════╝");
    Serial.println();
}

// ============================================
// LOOP
// ============================================
void loop() {
    readGPS();

    if (millis() - lastStatusPrint >= 5000) {
        lastStatusPrint = millis();

        unsigned long age = gps.location.isValid()
                            ? gps.location.age() : 99999;

        Serial.println("┌──────────── STATUS ──────────┐");
        Serial.printf("│ Chars      : %-16lu│\n",
                      gpsCharsReceived);
        Serial.printf("│ Satellites : %-16d│\n",
                      currentSats);
        Serial.printf("│ Data Age   : %-13lums│\n", age);
        Serial.printf("│ WiFi       : %-16s│\n",
            WiFi.status() == WL_CONNECTED
            ? "Connected ✓" : "Disconnected ✗");
        if (gpsFix) {
            Serial.printf("│ LAT: %-25.6f│\n", currentLat);
            Serial.printf("│ LNG: %-25.6f│\n", currentLng);  
            Serial.println("│ Fix: YES ✓  LED: Fast       │");
        } else {
            Serial.println("│ Fix: NO     LED: Slow       │");
        }
        Serial.println("└──────────────────────────────┘");
    }

    delay(10);
}
