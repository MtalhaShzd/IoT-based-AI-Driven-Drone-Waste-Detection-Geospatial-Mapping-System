# ============================================
# CSV Logger
# ============================================
def init_csv():
    if not os.path.exists(LOG_FILE):
        with open(LOG_FILE, 'w', newline='') as f:
            writer = csv.writer(f)
            writer.writerow([
                "timestamp", "result", "confidence_%",
                "latitude", "longitude", "satellites", "gps_fix", "google_maps_url"
            ])

def log_detection(result, confidence, gps):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    lat  = gps.get("lat", 0.0)
    lng  = gps.get("lng", 0.0)
    sats = gps.get("satellites", 0)
    fix  = gps.get("fix", False)
    maps_url = (
        f"https://maps.google.com/?q={lat},{lng}"
        if lat != 0 and lng != 0 else "no-fix"
    )

    if result == "garbage":
        row = {
            "timestamp"  : timestamp,
            "result"     : result,
            "confidence" : confidence,
            "lat"        : lat,
            "lng"        : lng,
            "satellites" : sats,
            "fix"        : fix,
            "maps_url"   : maps_url
        }
        with garbage_lock:
            garbage_log.append(row)
            if len(garbage_log) > 200:
                garbage_log.pop(0)

        try:
            with open(LOG_FILE, 'a', newline='') as f:
                writer = csv.writer(f)
                writer.writerow([
                    timestamp, result, confidence,
                    lat, lng, sats, fix, maps_url
                ])
        except Exception as e:
            print(f"[LOG] Error: {e}")

# ============================================
# AI Prediction
# ============================================
predict_lock  = threading.Lock()
is_predicting = False

def run_prediction(frame_data):
    global current_result, is_predicting

    with predict_lock:
        if is_predicting:
            return
        is_predicting = True

    try:
        if isinstance(frame_data, bytes):
            np_arr = np.frombuffer(frame_data, np.uint8)
            frame  = cv2.imdecode(np_arr, cv2.IMREAD_COLOR)
        else:
            frame = frame_data

        if frame is None:
            return

        img = cv2.resize(frame, (224, 224))
        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        img = img.astype(np.float32) / 255.0
        img = np.expand_dims(img, axis=0)

        prediction = model.predict(img, verbose=0)
        result     = classes[int(np.argmax(prediction))]
        confidence = round(float(np.max(prediction)) * 100, 2)

        with result_lock:
            current_result = {
                "result"     : result,
                "confidence" : confidence,
                "timestamp"  : datetime.now().strftime("%H:%M:%S")
            }

        if result == "garbage":
            stats["garbage_count"] += 1
        else:
            stats["clean_count"] += 1
        stats["frames_analyzed"] += 1

        with gps_lock:
            gps_snap = current_gps.copy()

        log_detection(result, confidence, gps_snap)

        icon = "🗑️ GARBAGE" if result == "garbage" else "✅ CLEAN"
        print(f"[AI] {icon} {confidence:.1f}% | GPS:{gps_snap['lat']:.5f},{gps_snap['lng']:.5f}")

    except Exception as e:
        print(f"[AI] Error: {e}")
    finally:
        with predict_lock:
            is_predicting = False

# ============================================
# STREAM READERS
# ============================================
def read_mjpeg_stream():
    global current_frame
    print(f"[STREAM] Connecting to {STREAM_URL}")
    ANALYZE_EVERY = 5
    frame_count   = 0

    while True:
        try:
            resp = requests.get(STREAM_URL, stream=True, timeout=20,
                                headers={"Connection": "keep-alive"})
            bytes_data = b""
            print("[STREAM] Connected ✓")

            for chunk in resp.iter_content(chunk_size=8192):
                bytes_data += chunk
                while True:
                    start = bytes_data.find(b'\xff\xd8')
                    end   = bytes_data.find(b'\xff\xd9')
                    if start == -1 or end == -1 or end <= start:
                        break
                    jpg        = bytes_data[start:end+2]
                    bytes_data = bytes_data[end+2:]
                    frame_count += 1
                    stats["frames_received"] += 1
                    with frame_lock:
                        current_frame = jpg
                    if frame_count % ANALYZE_EVERY == 0:
                        t = threading.Thread(target=run_prediction, args=(jpg,), daemon=True)
                        t.start()
                    if len(bytes_data) > 500000:
                        bytes_data = b""

        except Exception as e:
            stats["stream_errors"] += 1
            print(f"[STREAM] Error: {e} — retry 3s...")
            time.sleep(3)

def read_pc_webcam():
    global current_frame
    print("[WEBCAM] Opening USB camera...")
    cap = cv2.VideoCapture(0)
    cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
    cap.set(cv2.CAP_PROP_FPS, 30)

    if not cap.isOpened():
        print("[WEBCAM] Failed to open camera!")
        return

    print("[WEBCAM] Connected ✓")
    frame_count   = 0
    ANALYZE_EVERY = 10

    while True:
        ret, frame = cap.read()
        if not ret:
            time.sleep(0.1)
            continue
        _, buf = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 80])
        jpg = buf.tobytes()
        with frame_lock:
            current_frame = jpg
        stats["frames_received"] += 1
        frame_count += 1
        if frame_count % ANALYZE_EVERY == 0:
            t = threading.Thread(target=run_prediction, args=(frame.copy(),), daemon=True)
            t.start()
        time.sleep(0.033)

# ============================================
# GPS POLLING
# ============================================
def read_gps():
    global current_gps
    print(f"[GPS] Polling {GPS_URL}")
    while True:
        try:
            resp = requests.get(GPS_URL, timeout=5)
            data = resp.json()
            with gps_lock:
                current_gps = {
                    "lat"       : float(data.get("lat", 0.0)),
                    "lng"       : float(data.get("lng", 0.0)),
                    "satellites": int(data.get("satellites", 0)),
                    "fix"       : bool(data.get("fix", False))
                }
            fix = "✓" if current_gps["fix"] else "✗"
            print(f"[GPS] {fix} {current_gps['lat']:.6f},{current_gps['lng']:.6f} Sats:{current_gps['satellites']}")
        except Exception as e:
            stats["gps_errors"] += 1
            print(f"[GPS] Error: {e}")
        time.sleep(3)

