# Flask Routes
# ============================================
def generate_frames():
    while True:
        with frame_lock:
            frame = current_frame
        if frame is not None:
            yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + frame + b'\r\n')
        time.sleep(0.033)

@app.route('/video_feed')
def video_feed():
    return Response(generate_frames(), mimetype='multipart/x-mixed-replace; boundary=frame')

@app.route('/result')
def get_result():
    with result_lock:
        return jsonify(current_result)

@app.route('/gps')
def get_gps():
    with gps_lock:
        return jsonify(current_gps)

@app.route('/history')
def get_history():
    with garbage_lock:
        return jsonify(garbage_log[-50:])

@app.route('/stats')
def get_stats():
    return jsonify(stats)

@app.route('/export/csv')
def export_csv():
    """Export all garbage detections as a clean, well-formatted CSV."""
    output = io.StringIO()
    writer = csv.writer(output)

    # Header with metadata
    writer.writerow(["# Drone Waste Detection System — Export"])
    writer.writerow([f"# Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"])
    writer.writerow([f"# Session Start: {stats.get('session_start', 'N/A')}"])
    writer.writerow([f"# Camera Source: {stats.get('source', 'unknown').upper()}"])
    writer.writerow([f"# Total Detections: {len(garbage_log)}"])
    writer.writerow([])  # blank line

    # Column headers
    writer.writerow([
        "No.", "Timestamp", "Result", "Confidence (%)",
        "Latitude", "Longitude", "Satellites", "GPS Fix", "Google Maps URL"
    ])

    # Data rows
    with garbage_lock:
        for i, row in enumerate(garbage_log, 1):
            writer.writerow([
                i,
                row.get("timestamp", ""),
                row.get("result", "").upper(),
                row.get("confidence", ""),
                row.get("lat", ""),
                row.get("lng", ""),
                row.get("satellites", ""),
                "YES" if row.get("fix") else "NO",
                row.get("maps_url", "")
            ])

    output.seek(0)
    filename = f"waste_detections_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
    return Response(
        output.getvalue(),
        mimetype="text/csv",
        headers={"Content-Disposition": f"attachment; filename={filename}"}
    )

@app.route('/export/summary')
def export_summary():
    """Return a JSON summary of the session."""
    total = stats["garbage_count"] + stats["clean_count"]
    return jsonify({
        "session_start"    : stats.get("session_start"),
        "camera_source"    : stats.get("source"),
        "frames_received"  : stats["frames_received"],
        "frames_analyzed"  : stats["frames_analyzed"],
        "garbage_detections": stats["garbage_count"],
        "clean_detections" : stats["clean_count"],
        "garbage_rate_pct" : round(stats["garbage_count"] / total * 100, 1) if total > 0 else 0,
        "stream_errors"    : stats["stream_errors"],
        "gps_errors"       : stats["gps_errors"],
        "log_entries"      : len(garbage_log)
    })

