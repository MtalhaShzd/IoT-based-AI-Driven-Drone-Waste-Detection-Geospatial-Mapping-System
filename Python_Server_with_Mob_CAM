    font-family: var(--mono);
    font-size: 10px;
    opacity: 0.8;
  }

  .loc-link:hover { opacity: 1; text-decoration: underline; }
  .loc-none { color: var(--muted); font-size: 11px; font-family: var(--mono); }

  .history-wrap { max-height: 280px; overflow-y: auto; }
  .history-wrap::-webkit-scrollbar { width: 4px; }
  .history-wrap::-webkit-scrollbar-track { background: transparent; }
  .history-wrap::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .empty-state {
    padding: 32px;
    text-align: center;
    color: var(--muted);
    font-size: 12px;
    font-family: var(--mono);
    letter-spacing: 0.1em;
  }

  /* ── BOTTOM ROW ── */
  .bottom-row {
    grid-column: 1 / -1;
  }

  /* scrollbar for full-width section */
  .bottom-row .history-wrap { max-height: 240px; }

  /* ── TIME ── */
  #clock {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* ── SCAN LINE EFFECT ── */
  .video-scanline::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.4;
    animation: scan 3s linear infinite;
  }

  @keyframes scan {
    0%   { top: 0%; }
    100% { top: 100%; }
  }

  /* ── PROGRESS RING (GPS satellites) ── */
  .sats-ring {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .sat-pip {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.3s;
  }

  .sat-pip.on { background: var(--green); box-shadow: 0 0 4px var(--green); }
</style>
</head>
<body>
<div class="everything">

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-icon">🛸</div>
    <div>
      <div class="logo-text">DRONEEYE</div>
      <div class="logo-sub">Waste Detection System</div>
    </div>
  </div>
  <div class="header-right">
    <span id="clock">--:--:--</span>
    <div class="live-badge"><div class="live-dot"></div>LIVE</div>
    <a href="/export/csv" class="export-btn">⬇ Export CSV</a>
  </div>
</header>

<div class="layout">

  <!-- LEFT COL: Video + Stats + History -->
  <div style="display:flex;flex-direction:column;gap:14px;">

    <!-- Video Feed -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot"></span>Live Camera Feed</div>
        <span id="source-chip" class="overlay-chip active" style="font-size:10px;">● STREAMING</span>
      </div>
      <div class="video-wrap video-scanline">
        <img id="stream-img" src="/video_feed" alt="Camera Feed">
        <div class="video-overlay">
          <span class="overlay-chip" id="frame-chip">0 fps</span>
        </div>
      </div>
    </div>

    <!-- Session Stats -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot"></span>Session Statistics</div>
        <span id="session-time" style="font-size:11px;color:var(--muted);font-family:var(--mono);">—</span>
      </div>
      <div class="card-body">
        <div class="stats-row">
          <div class="stat-box">
            <div class="stat-num" id="s-frames">0</div>
            <div class="stat-label">Frames Recv</div>
          </div>
          <div class="stat-box">
            <div class="stat-num" id="s-analyzed">0</div>
            <div class="stat-label">Analyzed</div>
          </div>
          <div class="stat-box">
            <div class="stat-num red" id="s-garbage">0</div>
            <div class="stat-label">Garbage</div>
          </div>
          <div class="stat-box">
            <div class="stat-num green" id="s-clean">0</div>
            <div class="stat-label">Clean</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- RIGHT COL: Detection + GPS -->
  <div style="display:flex;flex-direction:column;gap:14px;">

    <!-- Detection Result -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="dot"></span>AI Detection</div>
        <span id="result-time" style="font-family:var(--mono);font-size:10px;color:var(--muted);">—</span>
      </div>
      <div class="card-body">
