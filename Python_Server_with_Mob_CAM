<script>
// ── Clock ──
function tickClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toTimeString().slice(0,8);
}
setInterval(tickClock, 1000);
tickClock();

// ── Result ──
var lastFrameCount = 0;
var lastFrameTime  = Date.now();

function updateResult() {
  fetch('/result').then(r=>r.json()).then(d=>{
    const panel = document.getElementById('result-panel');
    const icon  = document.getElementById('result-icon');
    const label = document.getElementById('result-label');
    const bar   = document.getElementById('conf-bar');
    const conf  = document.getElementById('conf-value');
    const ts    = document.getElementById('result-time');

    if (d.result === 'waiting') {
      panel.className = 'waiting';
      icon.textContent = '⏳';
      label.textContent = 'CONNECTING';
      bar.style.width = '0%';
      conf.textContent = '—';
      return;
    }

    panel.className = d.result;
    icon.textContent = d.result === 'garbage' ? '🗑️' : '✅';
    label.textContent = d.result === 'garbage' ? 'GARBAGE' : 'CLEAN';
    bar.style.width = d.confidence + '%';
    conf.textContent = d.confidence + '%';
    ts.textContent = d.timestamp || '';
  }).catch(()=>{});
}

// ── GPS ──
function updateGPS() {
  fetch('/gps').then(r=>r.json()).then(d=>{
    const ok = d.fix && d.lat !== 0 && d.lng !== 0;
    const fixEl = document.getElementById('g-fix');
    fixEl.textContent  = ok ? 'Fixed ✓' : 'Acquiring...';
    fixEl.className    = 'gps-val ' + (ok ? 'fix-ok' : 'fix-no');
    document.getElementById('g-lat').textContent  = ok ? d.lat.toFixed(6) + '°' : '—';
    document.getElementById('g-lng').textContent  = ok ? d.lng.toFixed(6) + '°' : '—';
    document.getElementById('g-sats').textContent = d.satellites || '0';

    // Satellite pips
    const pips = document.querySelectorAll('#sats-ring .sat-pip');
    const sats = Math.min(d.satellites || 0, 6);
    pips.forEach((p, i) => p.classList.toggle('on', i < sats));

    const btn = document.getElementById('maps-btn');
    if (ok) {
      btn.href = 'https://maps.google.com/?q=' + d.lat + ',' + d.lng;
      btn.classList.remove('disabled');
    } else {
      btn.href = '#';
      btn.classList.add('disabled');
    }
  }).catch(()=>{});
}

// ── Stats ──
var prevFrames = 0;
function updateStats() {
  fetch('/stats').then(r=>r.json()).then(d=>{
    document.getElementById('s-frames').textContent   = (d.frames_received||0).toLocaleString();
    document.getElementById('s-analyzed').textContent = (d.frames_analyzed||0).toLocaleString();
    document.getElementById('s-garbage').textContent  = (d.garbage_count||0).toLocaleString();
    document.getElementById('s-clean').textContent    = (d.clean_count||0).toLocaleString();
    if (d.session_start) {
      document.getElementById('session-time').textContent = 'Since ' + d.session_start.slice(11,16);
    }
  }).catch(()=>{});
}

// ── History ──
function updateHistory() {
  fetch('/history').then(r=>r.json()).then(items=>{
    const wrap = document.getElementById('history-wrap');
    if (!items || items.length === 0) {
      wrap.innerHTML = '<div class="empty-state">NO DETECTIONS YET</div>';
      return;
    }
    const rows = items.slice().reverse().map((item, i) => {
      const isGarbage = item.result === 'garbage';
      const badge = `<span class="badge ${item.result}">${isGarbage ? '🗑 ' : '✅ '}${item.result.toUpperCase()}</span>`;
      const loc = (item.lat !== 0)
        ? `<a class="loc-link" href="${item.maps_url}" target="_blank">📍${item.lat.toFixed(4)},${item.lng.toFixed(4)}</a>`
        : `<span class="loc-none">no GPS</span>`;
      return `<tr>
        <td style="font-family:var(--mono);font-size:11px;color:var(--muted)">${item.timestamp}</td>
        <td>${badge}</td>
        <td><span class="conf-pill">${item.confidence}%</span></td>
        <td>${loc}</td>
        <td style="font-family:var(--mono);font-size:10px;color:var(--muted)">${item.satellites||0} sat</td>
      </tr>`;
    }).join('');

    wrap.innerHTML = `
      <table class="history-table">
        <thead><tr>
          <th>Timestamp</th><th>Result</th><th>Confidence</th><th>Location</th><th>Sats</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
  }).catch(()=>{});
}

setInterval(updateResult,  800);
setInterval(updateGPS,     3000);
setInterval(updateStats,   1500);
setInterval(updateHistory, 4000);

updateResult(); updateGPS(); updateStats(); updateHistory();
</script>
</body>
</html>'''

